<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<key>CFBundleDevelopmentRegion</key>
	<string>$(DEVELOPMENT_LANGUAGE)</string>
	<key>CFBundleDisplayName</key>
	<string>Door Unlocker</string>
	<key>CFBundleExecutable</key>
	<string>$(EXECUTABLE_NAME)</string>
	<key>CFBundleIdentifier</key>
	<string>$(PRODUCT_BUNDLE_IDENTIFIER)</string>
	<key>CFBundleInfoDictionaryVersion</key>
	<string>6.0</string>
	<key>CFBundleName</key>
	<string>$(PRODUCT_NAME)</string>
	<key>CFBundlePackageType</key>
	<string>APPL</string>
	<key>CFBundleShortVersionString</key>
	<string>$(MARKETING_VERSION)</string>
	<key>CFBundleURLTypes</key>
	<array>
		<dict>
			<key>CFBundleURLName</key>
			<string>io.github.bt1142msstate.DoorUnlocker</string>
			<key>CFBundleURLSchemes</key>
			<array>
				<string>doorunlocker</string>
			</array>
		</dict>
	</array>
	<key>CFBundleVersion</key>
	<string>$(CURRENT_PROJECT_VERSION)</string>
	<key>DoorControllerFirmwareVersion</key>
	<string>0.1.32</string>
	<key>NSBluetoothAlwaysUsageDescription</key>
	<string>Door Unlocker uses Bluetooth to connect to your XIAO desk-test controller.</string>
	<key>NSFaceIDUsageDescription</key>
	<string>Door Unlocker can require Face ID or your device passcode before sending unlock commands.</string>
	<key>NSLocationAlwaysAndWhenInUseUsageDescription</key>
	<string>Door Unlocker uses your lock zone to avoid proximity unlock while you are still near your door.</string>
	<key>NSLocationTemporaryUsageDescriptionDictionary</key>
	<dict>
		<key>LockZonePrecision</key>
		<string>Door Unlocker uses precise location to decide whether your phone is inside the saved lock zone before proximity unlock can arm.</string>
	</dict>
	<key>NSLocationWhenInUseUsageDescription</key>
	<string>Door Unlocker uses your location to set and check the lock zone for proximity unlock.</string>
	<key>NSSupportsLiveActivities</key>
	<true/>
	<key>UIBackgroundModes</key>
	<array>
		<string>bluetooth-central</string>
		<string>location</string>
	</array>
	<key>UILaunchScreen</key>
	<dict>
		<key>UIColorName</key>
		<string>LaunchBackground</string>
	</dict>
	<key>UISupportedInterfaceOrientations</key>
	<array>
		<string>UIInterfaceOrientationPortrait</string>
	</array>
	<key>UISupportedInterfaceOrientations~ipad</key>
	<array>
		<string>UIInterfaceOrientationPortrait</string>
		<string>UIInterfaceOrientationPortraitUpsideDown</string>
		<string>UIInterfaceOrientationLandscapeLeft</string>
		<string>UIInterfaceOrientationLandscapeRight</string>
	</array>
</dict>
</plist>
